# CI/CD environment — safe to commit, contains no real secrets.
# Used by docker-compose.ci.yml for GitHub Actions and local CI runs.

# Database
DATABASE_URL=postgresql+asyncpg://apliqa:apliqa@postgres:5432/apliqa

# LLM — mock provider: instant responses, no API key, no rate limits
LLM_PROVIDER=mock

# Placeholder keys (required by config validation, not used by mock provider)
MISTRAL_API_KEY=mock-not-used
OPENROUTER_API_KEY=mock-not-used
OPENAI_API_KEY=mock-not-used

# Ollama (not started in CI)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Auth
AUTH_PROVIDER=none

# CORS
APLIQA_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
