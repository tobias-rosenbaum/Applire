# Apliqa Development Environment — copy to .env.dev and fill in your values
# cp .env.dev.example .env.dev

APLIQA_EDITION=community

# Database
DATABASE_URL=postgresql+asyncpg://apliqa:apliqa@postgres:5432/apliqa

# LLM Provider — choose one: mistral | openai | ollama
LLM_PROVIDER=ollama
# Mistral (set LLM_Provider = mistral to use)
MISTRAL_API_KEY=your-mistral-api-key-here

# OpenAI or any OpenAI-compatible server (set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=your-openai-api-key-here
#OPENAI_MODEL=gpt-4o
# For LM Studio: set OPENAI_BASE_URL and leave OPENAI_API_KEY as any non-empty string
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_MODEL=deepseek/deepseek-r1-0528-qwen3-8b

# Ollama (set LLM_PROVIDER=ollama to use; start with: docker compose --profile ollama up)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek/deepseek-r1-0528-qwen3-8b

# Auth (no enforcement for Community dev)
AUTH_PROVIDER=none
