# Apliqa Development Environment — copy to .env.dev and fill in your values
# cp .env.dev.example .env.dev

APLIQA_EDITION=community

# Database
DATABASE_URL=postgresql+asyncpg://apliqa:apliqa@postgres:5432/apliqa

# LLM Provider
LLM_PROVIDER=mistral
MISTRAL_API_KEY=your-mistral-api-key-here

# Auth (no enforcement for MVP dev)
AUTH_PROVIDER=none
