# Applire — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Database
DATABASE_URL=postgresql+asyncpg://applire:applire@postgres:5432/applire

# LLM Provider — choose one: mistral | openrouter | openai | ollama
LLM_PROVIDER=mistral

# Mistral AI — EU-hosted, GDPR-native, default
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-medium-latest

# OpenRouter — multi-model gateway, recommended fallback (set LLM_PROVIDER=openrouter)
# Bypasses per-provider rate limits; keeps model parity with Mistral by default.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=mistralai/mistral-medium-3
#OPENROUTER_BASE_URL=                              # leave empty to use https://openrouter.ai/api/v1
# Raise for thinking/reasoning models (Qwen3, o3, DeepSeek-R1 etc.) — default 120s
LLM_TIMEOUT=180

# LLM review layer — max generator retries per reviewed step (ADR-021).
# Set to 0 to disable the review layer entirely.
#LLM_REVIEW_MAX_RETRIES=2

# OpenAI or any OpenAI-compatible server (set LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
#OPENAI_MODEL=gpt-4o
# For LM Studio: set OPENAI_BASE_URL and leave OPENAI_API_KEY as any non-empty string
#OPENAI_BASE_URL=http://host.docker.internal:1234/v1

# Ollama — fully offline (set LLM_PROVIDER=ollama)
# Start with: docker compose --profile ollama up
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Auth — 'none' disables authentication (appropriate for single-user self-hosted use).
# Zitadel OIDC integration is available in the Cloud Edition.
AUTH_PROVIDER=none

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# nginx reverse proxy — read/send timeout for proxied requests (seconds).
# LLM inference can take several minutes; set this above LLM_TIMEOUT to avoid nginx cutting the connection.
# Default: 300 (5 min). Must be greater than LLM_TIMEOUT.
#NGINX_PROXY_TIMEOUT=300

# Frontend API URL
# docker compose: leave NEXT_PUBLIC_API_URL empty — the nginx service at :80 routes /api/* to the backend.
# standalone (npm run dev outside Docker): set to http://localhost:8001 so the frontend talks to the backend directly.
#NEXT_PUBLIC_API_URL=http://localhost:8001
